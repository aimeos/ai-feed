{
	"name": "aimeos/ai-feed",
	"description": "Aimeos ai-feed extension",
	"keywords": ["aimeos", "extension"],
	"type": "aimeos-extension",
	"license": "LGPL-3.0",
	"prefer-stable": true,
	"minimum-stability": "dev",
	"require": {
		"php": "^8.0.11",
		"aimeos/aimeos-core": "2025.10.*",
		"aimeos/ai-admin-jqadm": "2025.10.*",
		"aimeos/ai-admin-graphql": "2025.10.*",
		"aimeos/ai-controller-jobs": "2025.10.*"
	},
	"require-dev": {
		"phpunit/phpunit": "~10.0||~11.0||~12.0"
	},
	"autoload": {
		"psr-4": {
			"Aimeos\\": "src"
		},
		"classmap": [
			"src"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Aimeos\\": "tests"
		},
		"classmap": [
			"tests"
		]
	}
}